<Window x:Class="FPlusClone.Views.SelectFolderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chuyển thư mục" Height="220" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White" BorderThickness="1" BorderBrush="#1877f2">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề -->
        <TextBlock Grid.Row="0" Text="Chọn thư mục đích:" FontWeight="Bold" FontSize="14"
                   Foreground="#1877f2" Margin="0,0,0,12"/>

        <!-- ComboBox chọn folder -->
        <ComboBox Grid.Row="1"
                  x:Name="FolderCombo"
                  ItemsSource="{Binding AvailableFolders}"
                  SelectedItem="{Binding SelectedFolder}"
                  FontSize="13" Height="32" Margin="0,0,0,8"/>

        <!-- Hiển thị số tài khoản sẽ được chuyển -->
        <TextBlock Grid.Row="2" FontSize="12" Foreground="#666" VerticalAlignment="Top" Margin="0,4,0,0">
            <Run Text="Sẽ chuyển "/>
            <Run Text="{Binding AccountCount, Mode=OneWay}" FontWeight="Bold" Foreground="#d93025"/>
            <Run Text=" tài khoản sang thư mục đã chọn."/>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Xác nhận" Command="{Binding ConfirmCommand}" Width="90" Margin="0,0,10,0"
                    Style="{StaticResource ModernButton}"
                    Background="#1877f2" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            <Button Content="Hủy" Command="{Binding CancelCommand}" Width="80"
                    Style="{StaticResource ModernButton}"/>
        </StackPanel>
    </Grid>
</Window>
