<Window x:Class="FPlusClone.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FPlusClone.ViewModels"
        xmlns:local="clr-namespace:FPlusClone.Views"
        xmlns:tabs="clr-namespace:FPlusClone.Views.Tabs"
        Title="Phần mềm quản lý tài khoản Facebook" Height="700" Width="1100"
        Icon="/Resources/facebook_logo.ico">


    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <local:MultiCommandParameterConverter x:Key="MultiParamConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
            <RowDefinition Height="Auto"/> <!-- Main Navigation -->
            <RowDefinition Height="Auto"/> <!-- Sub Tabs -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="Auto"/> <!-- Debug Console -->
            <RowDefinition Height="Auto"/> <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Top Status Bar -->
        <Border Grid.Row="0" Background="#f8f9fa" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="10,5">
            <DockPanel>
                <Rectangle Fill="{DynamicResource PrimaryBlueBrush}" Width="24" Height="24" RadiusX="12" RadiusY="12" DockPanel.Dock="Left" Margin="0,0,5,0"/>
                <Button Content="🔑" Command="{Binding ToggleDebugConsoleCommand}" ToolTip="Mở debug print" Background="Transparent" BorderThickness="0" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="Facebook Manager" VerticalAlignment="Center" FontWeight="Bold" Foreground="#1877f2" FontSize="16"/>

            </DockPanel>
        </Border>

        <!-- Main Navigation -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="5">
                <Button Content="Home" Style="{StaticResource ModernButton}" Command="{Binding ShowHomeCommand}" Margin="0,0,5,0"/>
                <Button Content="Chrome Manager" Command="{Binding ShowChromeCommand}" Margin="0,0,5,0">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChromeSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBlueBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Token Manager" Command="{Binding ShowTokenCommand}">

                    <Button.Style>

                        <Style TargetType="Button" BasedOn="{StaticResource ModernButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTokenSelected}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBlueBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <!-- Sub Tabs Area - chỉ hiển thị khi Chrome Manager được chọn -->
        <Border Grid.Row="2" Background="#f1f3f4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChromeSelected}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal" Margin="5,0">
                <ItemsControl ItemsSource="{Binding ChromeTabs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="{Binding Header}" Grid.ColumnSpan="2" Style="{StaticResource TabHeaderButton}" Command="{Binding DataContext.SelectTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Padding="15,5,25,5"/>
                                <Button Content="✕" Grid.Column="1" Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0" Background="Transparent" BorderThickness="0" Foreground="#d93025" FontSize="10" FontWeight="Bold">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Header}" Value="Quản lí tài khoản Fb">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="+" Width="30" Height="30" Margin="5,0" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="{DynamicResource PrimaryBlueBrush}" Command="{Binding ToggleModalCommand}"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="3">
            <!-- Home Dashboard View -->
            <ScrollViewer>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel Margin="30">
                    <TextBlock Text="Chào mừng bạn đến với Hệ Thống Dashboard" FontSize="28" FontWeight="Light" Foreground="{DynamicResource PrimaryBlueBrush}" Margin="0,0,0,5"/>

                    <TextBlock Text="Bản cập nhật v4.9.0.7 - Chuyên nghiệp và Tin cậy" FontSize="16" Foreground="#666" Margin="0,0,0,30"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="White" CornerRadius="8" BorderThickness="1" BorderBrush="#eee" Margin="5" Padding="25">
                            <StackPanel>
                                <TextBlock Text="Tổng quan hệ thống" FontWeight="Bold" FontSize="20" Margin="0,0,0,15"/>
                                <TextBlock Text="Phần mềm quản lý tài khoản Facebook là giải pháp tối ưu cho việc viral sản phẩm và quản lý cộng đồng. Hệ thống hỗ trợ đa dạng các hình thức từ trình duyệt Chrome đến kết nối Token API." TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,20"/>

                                <Button Content="Xem tài liệu hướng dẫn" Style="{StaticResource ModernButton}" Background="#eee"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource PrimaryBlueBrush}" CornerRadius="8" Margin="5" Padding="25">
                            <StackPanel>
                                <TextBlock Text="Thông báo mới nhất" FontWeight="Bold" FontSize="20" Foreground="White" Margin="0,0,0,15"/>
                                <TextBlock Text="• Nâng cấp hệ thống tự động giải captcha khi login Chrome." Foreground="#eee" Margin="0,0,0,8"/>
                                <TextBlock Text="• Cập nhật thuật toán quét group theo từ khóa mới nhất." Foreground="#eee" Margin="0,0,0,8"/>
                                <TextBlock Text="• Khắc phục lỗi hiển thị trên màn hình độ phân giải cao." Foreground="#eee" Margin="0,0,0,8"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- FPlus Chrome View (info panel - only when NO sub-tab or non-account tab selected) -->
            <Grid Margin="30">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- Hiển thị info Chrome Manager khi Chrome active + KHÔNG ở tab chức năng -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsChromeSelected}" Value="True"/>
                                    <Condition Binding="{Binding IsAccountTabSelected}" Value="False"/>
                                    <Condition Binding="{Binding IsChromeFunctionTabActive}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel>
                    <TextBlock Text="Chrome Manager - Browser Automation" FontSize="28" FontWeight="Light" Foreground="{DynamicResource PrimaryBlueBrush}" Margin="0,0,0,5"/>

                    <TextBlock Text="Điều khiển trình duyệt tự động, an toàn và chính xác" FontSize="16" Foreground="#666" Margin="0,0,0,30"/>
                    
                    <WrapPanel Orientation="Horizontal">
                        <Border Background="White" Width="200" Height="150" Margin="10" Padding="15" CornerRadius="8" BorderThickness="1" BorderBrush="#eee">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Mở Profile" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                                <TextBlock Text="Quản lý Chrome Profiles" Foreground="#999" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White" Width="200" Height="150" Margin="10" Padding="15" CornerRadius="8" BorderThickness="1" BorderBrush="#eee">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Quản lý Proxy" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                                <TextBlock Text="TM Proxy, Kiot Proxy..." Foreground="#999" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White" Width="200" Height="150" Margin="10" Padding="15" CornerRadius="8" BorderThickness="1" BorderBrush="#eee">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Lịch sử" FontWeight="Bold" FontSize="16" Margin="0,0,0,5" HorizontalAlignment="Center"/>
                                <TextBlock Text="Chi tiết quá trình chạy" Foreground="#999" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Grid>

            <!-- FPlus Token View -->
            <Grid Margin="30">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTokenSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel>
                    <TextBlock Text="Token Manager - API Management" FontSize="28" FontWeight="Light" Foreground="#d93025" Margin="0,0,0,5"/>

                    <TextBlock Text="Quản lý hàng loạt qua Token API, tốc độ và hiệu suất" FontSize="16" Foreground="#666" Margin="0,0,0,30"/>
                    
                    <Border Background="#fffaf0" Padding="20" BorderThickness="1" BorderBrush="#ffeeba">
                        <StackPanel>
                            <TextBlock Text="Lưu ý khi sử dụng Token" FontWeight="Bold" Foreground="#856404" Margin="0,0,0,10"/>
                            <TextBlock Text="Sử dụng Token EAAB cho các tác vụ check live/die và Token EAAG cho các tác vụ tương tác chuyên sâu. Hãy đảm bảo Token luôn ở trạng thái Live." TextWrapping="Wrap" Foreground="#856404"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Account Management Content -->
            <Grid Margin="10">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAccountTabSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0">
                    <Border DockPanel.Dock="Top" Margin="0,0,0,10" Padding="8,5" Background="#eaf2fb" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowAddFolderInput}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <TextBlock Text="Lọc:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" Width="100" Margin="0,0,5,0"/>
                                <ComboBox ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolder}" Width="120" Margin="0,0,2,0"/>
                                <Button Content="Xóa" Style="{StaticResource ModernButton}" Background="#d93025" 
                                        Command="{Binding DeleteFolderCommand}" Width="50" Margin="0,0,5,0"/>
                                <Button Content="+" Command="{Binding ToggleAddFolderCommand}" Width="25" Margin="0,0,15,0" Style="{StaticResource ModernButton}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlueBrush}"/>
                                
                                <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                         Width="180" Height="28" Margin="0,0,5,0" 
                                         VerticalContentAlignment="Center"
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                                <Button Content="Tìm" Command="{Binding SearchCommand}" Width="50" Margin="0,0,10,0" Style="{StaticResource ModernButton}"/>
                                
                                <Button Content="Tài khoản lỗi" Command="{Binding SelectErrorCommand}" Margin="0,0,5,0" Style="{StaticResource ModernButton}"/>
                                <Button Content="All" Command="{Binding SelectAllCommand}" Margin="0,0,15,0" Style="{StaticResource ModernButton}"/>
                                
                                <TextBlock Text="|" VerticalAlignment="Center" Margin="5,0" Foreground="#ddd"/>
                                <TextBlock Text="Đã chọn: " VerticalAlignment="Center" Foreground="#666"/>
                                <TextBlock Text="{Binding SelectedCount}" VerticalAlignment="Center" Foreground="#d93025" FontWeight="Bold"/>
                            </WrapPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowAddFolderInput}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Tên thư mục mới:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Text="{Binding NewFolderName, UpdateSourceTrigger=PropertyChanged}" Width="200" Margin="0,0,10,0" VerticalContentAlignment="Center"/>
                                <Button Content="OK" Command="{Binding ConfirmAddFolderCommand}" Width="50" Margin="0,0,5,0" Style="{StaticResource ModernButton}" Background="{DynamicResource PrimaryBlueBrush}" Foreground="White" FontWeight="Bold"/>
                                <Button Content="Hủy" Command="{Binding ToggleAddFolderCommand}" Width="50" Style="{StaticResource ModernButton}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <DataGrid x:Name="AccountGrid" ItemsSource="{Binding ItemsView}" 
                              Style="{StaticResource ModernDataGrid}"
                              SelectionChanged="DataGrid_SelectionChanged"
                              SelectionMode="Extended" SelectionUnit="FullRow"
                              CanUserAddRows="False" AutoGenerateColumns="False"
                              EnableRowVirtualization="True"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              VirtualizingStackPanel.CacheLengthUnit="Item"
                              VirtualizingStackPanel.CacheLength="10,10">


                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Live">
                                        <Setter Property="Background" Value="#e6ffed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Die">
                                        <Setter Property="Background" Value="#ffeef0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Checkpoint">
                                        <Setter Property="Background" Value="#ffeef0"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Confirm Email">
                                        <Setter Property="Background" Value="#ffeef0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>


                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Check Live"/>
                                <MenuItem Header="Check Live &amp; info"/>
                                <MenuItem Header="Check Live Info &amp; Login"/>
                                <MenuItem Header="Check..."/>
                                <Separator/>
                                <MenuItem Header="Chạy tính năng"/>
                                <MenuItem Header="View in Chrome"/>
                                <MenuItem Header="Login with User|Pass"/>
                                <MenuItem Header="Copy">
                                    <MenuItem Header="Copy UID" Command="{Binding CopyAccountsCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="UID"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Copy Pass" Command="{Binding CopyAccountsCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Pass"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Copy UID|Pass" Command="{Binding CopyAccountsCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="UID|Pass"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Copy Cookie" Command="{Binding CopyAccountsCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Cookie"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Copy Token" Command="{Binding CopyAccountsCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Token"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Copy Custom" Command="{Binding ShowCopyCustomCommand}"
                                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItems}"/>
                                    <MenuItem Header="Copy Full" Command="{Binding CopyAccountsCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Full"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                </MenuItem>

                                <MenuItem Header="Sửa">
                                    <MenuItem Header="Edit UserName" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="UserName"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit Password" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Password"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit Email|Pass" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="PassEmail"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit Cookie" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Cookie"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit Proxy SSH" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Proxy"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit Note" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Note"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit 2FAKey" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="2FA"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                    <MenuItem Header="Edit Folder" Command="{Binding BulkEditCommand}">
                                        <MenuItem.CommandParameter>
                                            <MultiBinding Converter="{StaticResource MultiParamConverter}">
                                                <Binding Source="Folder"/>
                                                <Binding RelativeSource="{RelativeSource AncestorType=ContextMenu}" Path="PlacementTarget.SelectedItems"/>
                                            </MultiBinding>
                                        </MenuItem.CommandParameter>
                                    </MenuItem>
                                </MenuItem>

                                <MenuItem Header="Move To"/>
                                <MenuItem Header="Xóa">
                                    <MenuItem Header="Xóa dòng chọn" Command="{Binding DeleteSelectedAccountsCommand}" 
                                              CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.SelectedItems}"/>
                                    <MenuItem Header="Xóa tất cả" Command="{Binding DeleteAllAccountsCommand}"/>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Vượt checkpoint"/>
                                <MenuItem Header="Backup Checkpoint"/>
                                <MenuItem Header="Hotmail"/>
                                <MenuItem Header="2FA"/>
                                <MenuItem Header="Ngôn ngữ"/>
                                <MenuItem Header="Get Token"/>
                                <MenuItem Header="Khác"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>


                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding IsSelected}" Width="30" Header="Chọn"/>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="30"/>
                            <DataGridTextColumn Header="UserName" Binding="{Binding UserName}" Width="100"/>
                            <DataGridTextColumn Header="Pass" Binding="{Binding Password}" Width="80"/>
                            <DataGridTextColumn Header="Uid" Binding="{Binding Uid}" Width="150"/>
                            <DataGridTextColumn Header="Tên" Binding="{Binding Name}" Width="120"/>
                            <DataGridTextColumn Header="Cookie" Binding="{Binding Cookie}" Width="100"/>
                            <DataGridTextColumn Header="Token" Binding="{Binding Token}" Width="100"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="100"/>
                            <DataGridTextColumn Header="PassEmail" Binding="{Binding PassEmail}" Width="100"/>
                            <DataGridTextColumn Header="2FA" Binding="{Binding TwoFA}" Width="60"/>
                            <DataGridTextColumn Header="Proxy" Binding="{Binding Proxy}" Width="100"/>
                            <DataGridTextColumn Header="UserAgent" Binding="{Binding UserAgent}" Width="120"/>
                            <DataGridTextColumn Header="Log" Binding="{Binding Status}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Live">
                                                <Setter Property="Background" Value="{StaticResource StatusLiveBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Confirm Email">
                                                <Setter Property="Background" Value="{StaticResource StatusErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Ghi chú" Binding="{Binding Note}" Width="150"/>
                        </DataGrid.Columns>

                    </DataGrid>
                </DockPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <Button Content="Thêm Tài Khoản" Command="{Binding ShowImportAccountCommand}" Style="{StaticResource ModernButton}" Margin="0,0,0,5"/>
                    <Button Content="Login Chrome" Style="{StaticResource ModernButton}" Margin="0,0,0,5" Background="{DynamicResource PrimaryBlueBrush}" Foreground="White" BorderThickness="0"/>
                    <Button Content="Import Từ File" Command="{Binding ImportFromFileCommand}" Style="{StaticResource ModernButton}" Margin="0,0,20,5"/>

                    <Button Content="⚙  Cài đặt" Command="{Binding ShowSettingsCommand}"
                            Style="{StaticResource ModernButton}" Margin="0,0,0,5"
                            FontWeight="SemiBold" Foreground="#1a73e8" BorderBrush="#1a73e8"/>



                    <Border Background="#f8f9fa" Padding="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,5,0,0">
                        <StackPanel>
                            <TextBlock Text="Thống kê thư mục" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding FolderStatistics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,3">
                                            <TextBlock Text="{Binding Name}" Foreground="#555"/>
                                            <TextBlock Text="{Binding Count}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlueBrush}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Separator Margin="0,5" Background="#eee"/>
                            <DockPanel>
                                <TextBlock Text="Tổng tài khoản" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="{Binding Accounts.Count}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="#d93025"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- Other Tabs Content -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <!-- Hiện khi KHÔNG phải Home / Chrome / Account / Token -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsAccountTabSelected}" Value="False"/>
                                    <Condition Binding="{Binding IsHomeSelected}" Value="False"/>
                                    <Condition Binding="{Binding IsChromeSelected}" Value="False"/>
                                    <Condition Binding="{Binding IsTokenSelected}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                            <!-- Hiện khi đang ở tab chức năng Chrome (Comment, Join group,...) -->
                            <DataTrigger Binding="{Binding IsChromeFunctionTabActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- Dynamic tab content based on SelectedTab.Header -->
                <ContentControl>
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab.Header}" Value="Comment like group">
                                    <Setter Property="Content">
                                        <Setter.Value><tabs:TabSpamGroupView/></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTab.Header}" Value="Tham gia nhóm">
                                    <Setter Property="Content">
                                        <Setter.Value><tabs:TabJoinGroupView/></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTab.Header}" Value="Nuôi tài khoản">
                                    <Setter Property="Content">
                                        <Setter.Value><tabs:TabNuoiTKView/></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTab.Header}" Value="Spam Keyword">
                                    <Setter Property="Content">
                                        <Setter.Value><tabs:TabSpamKeywordView/></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTab.Header}" Value="Rời nhóm">
                                    <Setter Property="Content">
                                        <Setter.Value><tabs:TabOutGroupView/></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SelectedTab.Header}" Value="Comment Page">
                                    <Setter Property="Content">
                                        <Setter.Value><tabs:TabSpamPageView/></Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
            </Grid>
        </Grid>

        <!-- Debug Console Overlay -->

        <Border Grid.Row="4" Background="#1e1e1e" BorderBrush="#333" BorderThickness="0,1,0,0" Height="150">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDebugConsoleVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#2d2d2d" Padding="5">
                    <DockPanel>
                        <TextBlock Text="DEBUG CONSOLE - [Diagnostic System]" Foreground="#aaa" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Content="✕" Command="{Binding ToggleDebugConsoleCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="#666"/>
                    </DockPanel>
                </Border>
                <ListBox Grid.Row="1" ItemsSource="{Binding DebugLogs}" Background="Transparent" BorderThickness="0" Padding="5">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="#00ff00" FontFamily="Consolas" FontSize="12"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Modal Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="6" Panel.ZIndex="1000">
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource ModalBackground}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowAddTabModal}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            
            <Border Background="#f0f2f5" CornerRadius="12" Width="700" Height="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="20" ShadowDepth="5"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="White" Padding="20" BorderBrush="#dadce0" BorderThickness="0,0,0,1" CornerRadius="12,12,0,0">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" Command="{Binding ToggleModalCommand}" Background="Transparent" BorderThickness="0" FontSize="18" Foreground="#666" Cursor="Hand" VerticalAlignment="Top"/>
                            <StackPanel>
                                <TextBlock Text="CHỌN CHỨC NĂNG MỚI" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryBlueBrush}" Margin="0,0,0,5"/>
                                <TextBlock Text="Chọn một trong các chức năng bên dưới để hiển thị giao diện cấu hình." FontSize="13" Foreground="#666"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Function List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                        <ItemsControl ItemsSource="{Binding AvailableFunctions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.AddTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                            CommandParameter="{Binding}"
                                            Margin="10" Width="280" Height="100" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="#dadce0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                                                    CornerRadius="8" Padding="15">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="6" ShadowDepth="1"/>
                                                                </Border.Effect>
                                                                <DockPanel>
                                                                    <TextBlock Text="⚡" FontSize="24" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{DynamicResource PrimaryBlueBrush}"/>
                                                                    <StackPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" Foreground="#333" Margin="0,0,0,5"/>
                                                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#666" TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#f8faff"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlueBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="5" Background="#f1f3f4" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="10,2">
            <DockPanel>
                <TextBlock Text="Hỗ trợ: 090.173.1871 | Plus24h.com" VerticalAlignment="Center"/>
                <TextBlock Text="Version 4.9.0.7" DockPanel.Dock="Right" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
        <!-- Loading Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="6" Background="#80000000" Panel.ZIndex="2000">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border Background="White" CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressMessage}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <ProgressBar Height="15" Minimum="0" Maximum="{Binding ProgressTotal}" Value="{Binding ProgressCurrent}" Margin="0,0,0,10"/>
                    <TextBlock HorizontalAlignment="Center" FontSize="14" Foreground="#666">
                        <Run Text="Đang xử lý: "/>
                        <Run Text="{Binding ProgressCurrent, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding ProgressTotal, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

