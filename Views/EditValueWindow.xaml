<Window x:Class="FPlusClone.Views.EditValueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="200" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="White" BorderThickness="1" BorderBrush="{DynamicResource PrimaryBlueBrush}">
    
    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Prompt}" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <TextBox Grid.Row="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalAlignment="Top" Padding="5" Margin="0,0,0,10"
                 AcceptsReturn="True" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Xác nhận" Command="{Binding SaveCommand}" Width="80" Margin="0,0,10,0"
                    Style="{StaticResource ModernButton}" Background="{DynamicResource PrimaryBlueBrush}" Foreground="White" BorderThickness="0"/>
            <Button Content="Hủy" Command="{Binding CloseCommand}" Width="80"
                    Style="{StaticResource ModernButton}"/>
        </StackPanel>
    </Grid>
</Window>
