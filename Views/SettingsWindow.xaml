<Window x:Class="FPlusClone.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt" Height="540" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        BorderThickness="1"
        BorderBrush="#dadce0"
        WindowStyle="None"
        AllowsTransparency="False">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </Window.Resources>

    <Border BorderBrush="#dadce0" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>  <!-- Title bar -->
                <RowDefinition Height="*"/>   <!-- Body -->
                <RowDefinition Height="52"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════ -->
            <!--  TITLE BAR                                         -->
            <!-- ══════════════════════════════════════════════════ -->
            <Border Grid.Row="0" Background="#1a73e8">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚙" FontSize="16" Foreground="White"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Cài đặt hệ thống" FontSize="14"
                                   FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right"
                            Command="{Binding CancelCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="White" FontSize="14" FontWeight="Bold"
                            Width="36" Height="36" Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1557b0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════ -->
            <!--  BODY: LEFT NAV  +  RIGHT CONTENT                  -->
            <!-- ══════════════════════════════════════════════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>   <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>     <!-- Content -->
                </Grid.ColumnDefinitions>

                <!-- ── LEFT SIDEBAR ── -->
                <Border Grid.Column="0" Background="#f8f9fa"
                        BorderBrush="#dadce0" BorderThickness="0,0,1,0">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Section: Luồng & Chrome -->
                        <Border Background="#e8f0fe" BorderBrush="#1a73e8"
                                BorderThickness="3,0,0,0" Margin="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Margin="14,12">
                                <TextBlock Text="🔧" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Luồng &amp; Chrome" FontSize="12"
                                               FontWeight="Bold" Foreground="#1a73e8"/>
                                    <TextBlock Text="Cấu hình chạy" FontSize="10" Foreground="#5f6368"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Section: Proxy (mờ hơn, không active) -->
                        <Border Background="Transparent" Margin="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Margin="17,12">
                                <TextBlock Text="🌐" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Proxy" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#3c4043"/>
                                    <TextBlock Text="Cài đặt kết nối" FontSize="10" Foreground="#5f6368"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Section: Chrome Options -->
                        <Border Background="Transparent" Margin="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Margin="17,12">
                                <TextBlock Text="🖥" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Chrome" FontSize="12"
                                               FontWeight="SemiBold" Foreground="#3c4043"/>
                                    <TextBlock Text="Tùy chọn trình duyệt" FontSize="10" Foreground="#5f6368"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Separator Background="#dadce0" Margin="12,8"/>

                        <StackPanel Margin="14,4">
                            <TextBlock Text="settings.json" FontSize="10"
                                       Foreground="#9aa0a6" FontFamily="Consolas"/>
                            <TextBlock Text="Tự động lưu khi nhấn Lưu"
                                       FontSize="10" Foreground="#9aa0a6" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── RIGHT CONTENT ── -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              Background="White">
                    <StackPanel Margin="28,20,28,20">

                        <!-- ══ SECTION 1: Luồng & Chrome ══ -->
                        <TextBlock Text="Cấu hình Luồng &amp; Chrome"
                                   FontSize="15" FontWeight="Bold" Foreground="#1a73e8"
                                   Margin="0,0,0,4"/>
                        <Separator Background="#e8f0fe" Margin="0,0,0,16"/>

                        <!-- Số luồng -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Số luồng chạy" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#202124"/>
                                <TextBlock Text="Số tài khoản được xử lý song song cùng lúc"
                                           FontSize="11" Foreground="#5f6368" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" BorderBrush="#dadce0" BorderThickness="1"
                                    Background="White">
                                <TextBox Text="{Binding ThreadCount, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6" FontSize="13" BorderThickness="0"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Số Chrome/hàng -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Số Chrome trên 1 hàng" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#202124"/>
                                <TextBlock Text="Bố cục cửa sổ Chrome khi chạy nhiều profile"
                                           FontSize="11" Foreground="#5f6368" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" BorderBrush="#dadce0" BorderThickness="1"
                                    Background="White">
                                <TextBox Text="{Binding ChromePerRow, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,6" FontSize="13" BorderThickness="0"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- ══ SECTION 2: Proxy ══ -->
                        <TextBlock Text="Cấu hình Proxy"
                                   FontSize="15" FontWeight="Bold" Foreground="#1a73e8"
                                   Margin="0,4,0,4"/>
                        <Separator Background="#e8f0fe" Margin="0,0,0,16"/>

                        <!-- Toggle: Dùng Proxy -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Bật Proxy" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#202124"/>
                                <TextBlock Text="Gán proxy cho tài khoản khi chạy tác vụ"
                                           FontSize="11" Foreground="#5f6368" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding UseProxy}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Proxy list -->
                        <TextBlock Text="Danh sách Proxy  (1 proxy / dòng — ip:port  hoặc  ip:port:user:pass)"
                                   FontSize="11" Foreground="#5f6368" Margin="0,0,0,6"/>
                        <Border BorderBrush="#dadce0" BorderThickness="1">
                            <TextBox Text="{Binding ProxyList, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="80" Padding="10,8"
                                     FontSize="12" FontFamily="Consolas"
                                     BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto"
                                     IsEnabled="{Binding UseProxy}"
                                     Background="White"/>
                        </Border>

                        <!-- ══ SECTION 3: Chrome Options ══ -->
                        <TextBlock Text="Tùy chọn Chrome"
                                   FontSize="15" FontWeight="Bold" Foreground="#1a73e8"
                                   Margin="0,20,0,4"/>
                        <Separator Background="#e8f0fe" Margin="0,0,0,16"/>

                        <!-- Tắt load ảnh -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Tắt tải ảnh" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#202124"/>
                                <TextBlock Text="Tăng tốc độ chạy, giảm băng thông tiêu thụ"
                                           FontSize="11" Foreground="#5f6368" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding DisableImageLoad}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Ẩn Chrome -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Ẩn Chrome (Headless)" FontSize="12"
                                           FontWeight="SemiBold" Foreground="#202124"/>
                                <TextBlock Text="Chạy nền, không hiển thị cửa sổ trình duyệt"
                                           FontSize="11" Foreground="#5f6368" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding HideChrome}"
                                      VerticalAlignment="Center"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ══════════════════════════════════════════════════ -->
            <!--  FOOTER                                            -->
            <!-- ══════════════════════════════════════════════════ -->
            <Border Grid.Row="2" Background="#f8f9fa"
                    BorderBrush="#dadce0" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <TextBlock Text="Cài đặt được lưu vào settings.json cùng thư mục exe"
                               FontSize="11" Foreground="#9aa0a6"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="Hủy" Command="{Binding CancelCommand}"
                                Width="80" Height="32" Margin="0,0,10,0"
                                Style="{StaticResource ModernButton}"/>
                        <Button Content="💾  Lưu cài đặt" Command="{Binding SaveCommand}"
                                Width="120" Height="32"
                                Background="#1a73e8" Foreground="White"
                                BorderThickness="0" FontWeight="SemiBold"
                                FontSize="12" Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#1a73e8"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1557b0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
