<UserControl x:Class="FPlusClone.Views.Tabs.TabNuoiTKView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f0f2f5">
    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/Styles.xaml"/>
    </UserControl.Resources>
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ CỘT TRÁI: TÀI KHOẢN ══ -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,15,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="👤" FontSize="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock Text="CHỌN TÀI KHOẢN" FontSize="14" FontWeight="Bold" Foreground="#fbbc04" VerticalAlignment="Center"/>
                </StackPanel>

                <DockPanel Grid.Row="1" Margin="0,0,0,10">
                    <TextBlock Text="Thư mục:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#555" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding Folders}" SelectedItem="{Binding SelectedFolder}" Height="30" 
                              Background="#f8f9fa" BorderBrush="#dadce0" Padding="5,0"/>
                </DockPanel>

                <Border Grid.Row="2" BorderBrush="#dadce0" BorderThickness="1" CornerRadius="4" Background="#fafbfc">
                    <ListView ItemsSource="{Binding ItemsView}" BorderThickness="0" Background="Transparent" 
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="Margin" Value="0,1"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#f0f0f0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#fff8e1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,2" LastChildFill="True">
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="#333" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Uid}" FontSize="11" Foreground="#888"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Grid.Row="3" Margin="0,10,0,0" Padding="10" Background="#f8f9fa" CornerRadius="4" BorderBrush="#dadce0" BorderThickness="1">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Chọn tất cả" Command="{Binding SelectAllCommand}" 
                                Style="{StaticResource ModernButton}" Padding="10,4" FontSize="11"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Đã chọn: " Foreground="#555" FontSize="12"/>
                            <TextBlock Text="{Binding SelectedCount}" FontWeight="Bold" Foreground="#fbbc04" FontSize="14"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══ CỘT PHẢI: SETTINGS & LOGS ══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HÀNG 1: CẤU HÌNH -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="⚙" FontSize="16" Margin="0,0,5,0" VerticalAlignment="Center" Foreground="#555"/>
                        <TextBlock Text="CẤU HÌNH NUÔI TÀI KHOẢN (WARM-UP)" FontSize="14" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Config Left -->
                        <StackPanel Grid.Column="0">
                            <Border Background="#f8f9fa" BorderBrush="#dadce0" BorderThickness="1" CornerRadius="4" Padding="15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Thời gian nuôi (giây)" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Tổng thời gian lướt feed / tài khoản" FontSize="11" Foreground="#888"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" BorderBrush="#dadce0" BorderThickness="1" Background="White" CornerRadius="4">
                                            <TextBox Text="180" BorderThickness="0" Padding="5" HorizontalContentAlignment="Center"/>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Tốc độ cuộn (pixel)" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="Min - Max cho mỗi lần cuộn" FontSize="11" Foreground="#888"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Border BorderBrush="#dadce0" BorderThickness="1" Background="White" CornerRadius="4" Width="40">
                                                <TextBox Text="400" BorderThickness="0" Padding="5" HorizontalContentAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="-" VerticalAlignment="Center" Margin="5,0"/>
                                            <Border BorderBrush="#dadce0" BorderThickness="1" Background="White" CornerRadius="4" Width="40">
                                                <TextBox Text="800" BorderThickness="0" Padding="5" HorizontalContentAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Config Right -->
                        <StackPanel Grid.Column="2">
                            <Border Background="#f8f9fa" BorderBrush="#dadce0" BorderThickness="1" CornerRadius="4" Padding="15">
                                <StackPanel>
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Ngẫu nhiên click bài viết" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="20% tỷ lệ click xem chi tiết bài" FontSize="11" Foreground="#888"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Thả cảm xúc ngẫu nhiên" FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Text="5% tỷ lệ thả Like/Tim" FontSize="11" Foreground="#888"/>
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" IsChecked="True" VerticalAlignment="Center">
                                            <CheckBox.LayoutTransform>
                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                            </CheckBox.LayoutTransform>
                                        </CheckBox>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- HÀNG 2: CONTROLS & LOG -->
            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Cursor="Hand" Width="130" Height="40" Margin="0,0,10,0" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#fbbc04"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="▶" Margin="0,0,8,0" FontSize="14"/>
                                                            <TextBlock Text="BẮT ĐẦU" FontWeight="Bold" FontSize="13"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#d4a004"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Cursor="Hand" Width="100" Height="40" BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#fce8e6"/>
                                        <Setter Property="Foreground" Value="#d93025"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <TextBlock Text="⏹" Margin="0,0,5,0" FontSize="14"/>
                                                            <TextBlock Text="Dừng" FontWeight="Bold" FontSize="13"/>
                                                        </StackPanel>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#f5caba"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border Background="#fff8e1" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Đã nuôi: " Foreground="#f57f17" FontSize="13"/>
                                    <TextBlock Text="0" FontWeight="Bold" Foreground="#f57f17" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#e8f0fe" CornerRadius="4" Padding="10,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Thời gian: " Foreground="#1a73e8" FontSize="13"/>
                                    <TextBlock Text="0m" FontWeight="Bold" Foreground="#1a73e8" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DockPanel>

                    <!-- LOG AREA -->
                    <Border Grid.Row="1" Background="White" CornerRadius="6" BorderBrush="#dadce0" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="#f8f9fa" Padding="10,8" CornerRadius="6,6,0,0" BorderBrush="#dadce0" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock Text="NHẬT KÝ HOẠT ĐỘNG" Foreground="#5f6368" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button DockPanel.Dock="Right" Content="Xóa Log" Background="Transparent" Foreground="#1a73e8" BorderThickness="0" HorizontalAlignment="Right" Cursor="Hand"/>
                                </DockPanel>
                            </Border>
                            <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="10">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="#333" FontSize="12" TextWrapping="Wrap" Margin="0,2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBoxItem>
                                    <TextBlock Text="[--:--:--] Hệ thống đã sẵn sàng..." Foreground="#888" FontSize="12"/>
                                </ListBoxItem>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
